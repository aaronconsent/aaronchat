# Copy each block to its own file (e.g., secrets/buffer.env) with real values.
# In CI, these are recreated from GitHub Secrets by .github/workflows/automation.yml.

# --- secrets/buffer.env ---
BUFFER_TOKEN=paste-buffer-api-token-here
BUFFER_ORG=aaron-chat-org-id
BUFFER_LINKEDIN_CHANNEL=channel-id-for-linkedin
BUFFER_X_CHANNEL=channel-id-for-x

# --- secrets/linkedin.env ---   (for future own_app backend; MVP uses Buffer)
LINKEDIN_ACCESS_TOKEN=paste-linkedin-token-here
LINKEDIN_ORGANIZATION_URN=urn:li:organization:XXXX

# --- secrets/x.env ---           (for future own_app backend; MVP uses Buffer)
X_BEARER_TOKEN=paste-x-bearer-token-here
X_API_KEY=paste-x-api-key
X_API_SECRET=paste-x-api-secret
X_ACCESS_TOKEN=paste-x-access-token
X_ACCESS_SECRET=paste-x-access-secret
